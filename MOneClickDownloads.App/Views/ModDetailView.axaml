<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MOneClickDownloads.App.ViewModels"
             xmlns:m="using:MOneClickDownloads.App.Models"
             xmlns:conv="using:MOneClickDownloads.App.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="550"
             x:Class="MOneClickDownloads.App.Views.ModDetailView"
             x:DataType="vm:ModDetailViewModel">

    <DockPanel>
        <!-- 顶部：返回按钮 + 模组信息 -->
        <Border DockPanel.Dock="Top" Padding="16,12">
            <StackPanel Spacing="8">
                <!-- 返回按钮 -->
                <Button Content="← 返回搜索" 
                        Command="{Binding GoBackCommand}"
                        HorizontalAlignment="Left"
                        Padding="8,4"/>
                
                <!-- 模组标题 -->
                <TextBlock Text="{Binding ProjectTitle}" 
                           FontSize="22" FontWeight="Bold"/>
                
                <!-- 模组描述 -->
                <TextBlock Text="{Binding ProjectDescription}" 
                           FontSize="15"
                           TextWrapping="Wrap"
                           MaxLines="3"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- 底部：下载状态栏 -->
        <Border DockPanel.Dock="Bottom" Padding="16,12"
                IsVisible="{Binding IsDownloading}">
            <StackPanel Spacing="8">
                <ProgressBar Value="{Binding DownloadProgressValue}" 
                             Maximum="100" Height="8"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding DownloadStatus}" 
                               FontSize="15"
                               VerticalAlignment="Center"/>
                    <Button Content="取消下载" 
                            Command="{Binding CancelDownloadCommand}"
                            Padding="12,6" FontSize="14"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 非下载时的底部状态文本 -->
        <Border DockPanel.Dock="Bottom" Padding="16,12"
                IsVisible="{Binding !IsDownloading}">
            <TextBlock Text="{Binding DownloadStatus}" 
                       FontSize="15"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </Border>

        <!-- 过滤标签区域 -->
        <Border DockPanel.Dock="Top" Padding="16,8"
                IsVisible="{Binding !IsLoading}">
            <StackPanel Spacing="6">
                <!-- 加载器过滤标签栏 -->
                <ItemsControl ItemsSource="{Binding AvailableLoaders}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Button Command="{Binding #VersionList.DataContext.ToggleLoaderFilterCommand}"
                                    CommandParameter="{Binding}"
                                    Padding="14,6"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate>
                                        <Border CornerRadius="20"
                                                Padding="{TemplateBinding Padding}"
                                                BorderThickness="1"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                Cursor="Hand">
                                            <Border.Background>
                                                <MultiBinding Converter="{x:Static conv:StringEqualsConverter.Instance}">
                                                    <Binding/>
                                                    <Binding Path="#VersionList.DataContext.ActiveLoaderFilter"
                                                             RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                </MultiBinding>
                                            </Border.Background>
                                            <TextBlock Text="{Binding}"
                                                       FontSize="15"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- MC版本过滤：可展开列表 -->
                <StackPanel>
                    <ToggleButton x:Name="McVersionToggle"
                                  Padding="12,6"
                                  HorizontalAlignment="Left"
                                  IsChecked="True"
                                  Background="Transparent"
                                  Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="MC版本"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding #McVersionToggle.IsChecked, 
                                       Converter={x:Static conv:BoolToArrowConverter.Instance}}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <!-- 动态箭头用 TextBlock 通过样式控制 -->
                            </TextBlock>
                        </StackPanel>
                    </ToggleButton>
                    <ScrollViewer MaxHeight="200"
                                  IsVisible="{Binding #McVersionToggle.IsChecked}"
                                  Margin="0,6,0,0">
                        <ItemsControl ItemsSource="{Binding AvailableMcVersions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Button Command="{Binding #VersionList.DataContext.ToggleMcVersionFilterCommand}"
                                            CommandParameter="{Binding}"
                                            Padding="14,6"
                                            Classes="mr-2 mb-2"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate>
                                                <Border CornerRadius="20"
                                                        Padding="{TemplateBinding Padding}"
                                                        Margin="{TemplateBinding Margin}"
                                                        BorderThickness="1"
                                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                        Cursor="Hand">
                                                    <Border.Background>
                                                        <MultiBinding Converter="{x:Static conv:StringEqualsConverter.Instance}">
                                                            <Binding/>
                                                            <Binding Path="#VersionList.DataContext.ActiveMcVersionFilter"
                                                                     RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                        </MultiBinding>
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding}"
                                                               FontSize="14"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <!-- 发布状态过滤标签栏 -->
                <ItemsControl ItemsSource="{Binding AvailableStatusFilters}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Button Command="{Binding #VersionList.DataContext.ToggleStatusFilterCommand}"
                                    CommandParameter="{Binding}"
                                    Padding="14,6"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate>
                                        <Border CornerRadius="20"
                                                Padding="{TemplateBinding Padding}"
                                                BorderThickness="1"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                Cursor="Hand">
                                            <Border.Background>
                                                <MultiBinding Converter="{x:Static conv:StringEqualsConverter.Instance}">
                                                    <Binding/>
                                                    <Binding Path="#VersionList.DataContext.ActiveStatusFilter"
                                                             RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                </MultiBinding>
                                            </Border.Background>
                                            <TextBlock Text="{Binding}"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- 中部：版本分组列表 -->
        <Panel>
            <!-- 加载中 -->
            <StackPanel IsVisible="{Binding IsLoading}" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Spacing="8">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="加载版本列表中..." 
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- 版本列表 -->
            <ScrollViewer IsVisible="{Binding !IsLoading}" Padding="16,0">
                <ItemsControl x:Name="VersionList" ItemsSource="{Binding VersionGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="m:McVersionGroup">
                            <StackPanel>
                                <ToggleButton x:Name="VersionToggle"
                                             Padding="12,10"
                                             HorizontalAlignment="Stretch"
                                             HorizontalContentAlignment="Stretch"
                                             Background="Transparent"
                                             BorderThickness="0,0,0,1"
                                             BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
                                    <DockPanel>
                                        <TextBlock Text="{Binding MajorVersion}" 
                                                   FontSize="16" FontWeight="SemiBold"
                                                   DockPanel.Dock="Left"/>
                                    </DockPanel>
                                </ToggleButton>
                                <ItemsControl ItemsSource="{Binding Versions}"
                                             IsVisible="{Binding IsChecked, ElementName=VersionToggle}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="m:ModVersionItem">
                                            <Button Padding="12,10"
                                                    Margin="0,4,0,0"
                                                    BorderThickness="1"
                                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                                    Background="Transparent"
                                                    HorizontalAlignment="Stretch"
                                                    Command="{Binding #VersionList.DataContext.DownloadVersionCommand}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Border CornerRadius="4"
                                                            Padding="6,2"
                                                            Background="{Binding DisplayTypeTag, 
                                                                Converter={x:Static conv:TypeTagBrushConverter.Instance}}">
                                                        <TextBlock Text="{Binding DisplayTypeTag}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding DisplayName}" 
                                                               FontSize="15"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Panel>
    </DockPanel>
</UserControl>