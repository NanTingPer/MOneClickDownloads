<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Padding (Border supports Padding) -->
    <Style Selector="Border.p-1">
        <Setter Property="Padding" Value="4"/>
    </Style>
    <Style Selector="Border.p-2">
        <Setter Property="Padding" Value="8"/>
    </Style>
    <Style Selector="Border.p-4">
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- Margin (Border & TextBlock) -->
    <Style Selector="Border.m-2">
        <Setter Property="Margin" Value="8"/>
    </Style>
    <Style Selector="Border.m-4">
        <Setter Property="Margin" Value="16"/>
    </Style>
    <Style Selector="TextBlock.m-2">
        <Setter Property="Margin" Value="8"/>
    </Style>
    <Style Selector="TextBlock.m-4">
        <Setter Property="Margin" Value="16"/>
    </Style>

    <!-- Layout (Control supports HorizontalAlignment & VerticalAlignment) -->
    <Style Selector="Control.w-full">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Control.h-full">
        <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Control.items-center">
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Text Typography -->
    <Style Selector="TextBlock.text-xl">
        <Setter Property="FontSize" Value="20"/>
    </Style>
    <Style Selector="TextBlock.text-2xl">
        <Setter Property="FontSize" Value="24"/>
    </Style>
    <Style Selector="TextBlock.text-lg">
        <Setter Property="FontSize" Value="18"/>
    </Style>
    <Style Selector="TextBlock.text-xs">
        <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="TextBlock.font-bold">
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style Selector="TextBlock.text-muted">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
    </Style>

    <!-- Colors -->
    <Style Selector="TextBlock.text-white">
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Border.bg-primary">
        <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
    </Style>
    <Style Selector="Border.bg-subtle">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
    </Style>
    <Style Selector="Border.bg-accent">
        <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
    </Style>

    <!-- Cursor -->
    <Style Selector="Control.cursor-pointer">
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- Border Radius -->
    <Style Selector="Border.rounded-full">
        <Setter Property="CornerRadius" Value="20"/>
    </Style>
    <Style Selector="Border.rounded-md">
        <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <!-- Spacing -->
    <Style Selector="StackPanel.gap-1">
        <Setter Property="Spacing" Value="4"/>
    </Style>
    <Style Selector="StackPanel.gap-2">
        <Setter Property="Spacing" Value="8"/>
    </Style>
    <Style Selector="StackPanel.gap-4">
        <Setter Property="Spacing" Value="16"/>
    </Style>
    <!-- Display -->
    <Style Selector="Border.inline-block">
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- Directional Margin -->
    <Style Selector="Button.mr-2">
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>
    <Style Selector="Button.mb-2">
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
    <Style Selector="Button.mr-2.mb-2">
        <Setter Property="Margin" Value="0,0,8,8"/>
    </Style>

    <!-- Border Sides -->
    <Style Selector="Border.border-b">
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- ===== 侧边栏导航 ===== -->

    <!-- 顶部工具栏 -->
    <Style Selector="Border.sidebar-toolbar">
        <Setter Property="Background" Value="{DynamicResource OpaqueLayerBrush}"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- 汉堡菜单切换按钮 -->
    <Style Selector="Button.sidebar-toggle-btn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="10"/>
    </Style>
    <Style Selector="Button.sidebar-toggle-btn:pointerover">
        <Setter Property="Background" Value="{DynamicResource SubtleBrush}"/>
    </Style>
    <Style Selector="Button.sidebar-toggle-btn:pressed">
        <Setter Property="Background" Value="{DynamicResource SubtleBrush}"/>
    </Style>

    <!-- 汉堡菜单横线 -->
    <Style Selector="Border.sidebar-icon-line">
        <Setter Property="Background" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        <Setter Property="CornerRadius" Value="1"/>
    </Style>

    <!-- 侧边栏遮罩层 -->
    <Style Selector="Border.sidebar-overlay">
        <Setter Property="Background" Value="Black"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="IsHitTestVisible" Value="True"/>
        <Setter Property="ZIndex" Value="10"/>
    </Style>

    <!-- 侧边栏面板 -->
    <Style Selector="Border.sidebar-panel">
        <Setter Property="Background" Value="{DynamicResource OpaqueLayerBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="ZIndex" Value="20"/>
    </Style>

    <!-- 侧边栏内容区域 -->
    <Style Selector="StackPanel.sidebar-content">
        <Setter Property="Margin" Value="8,8"/>
    </Style>

    <!-- 侧边栏分组标题 -->
    <Style Selector="TextBlock.sidebar-header">
        <Setter Property="Margin" Value="12,8,8,4"/>
    </Style>

    <!-- 侧边栏导航按钮 -->
    <Style Selector="Button.sidebar-nav-btn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>
    <Style Selector="Button.sidebar-nav-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SubtleBrush}"/>
    </Style>
    <Style Selector="Button.sidebar-nav-btn:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SubtleBrush}"/>
    </Style>
</Styles>